{{- /*
  OpenTofu provider/backend configuration for the cluster.
  This file configures the Terraform/OpenTofu backend. Resource definitions
  are rendered into main.tf from iac.main (locals) and iac.modules (modules).
*/ -}}

terraform {
  required_version = ">= 1.6.0"

  {{- $bt := .OpenTofu.Backend.Type | lower }}
  {{- $backendType := "local" }}
  {{- if eq $bt "s3" }}{{ $backendType = "s3" }}{{ end }}
  {{- if eq $bt "aws" }}{{ $backendType = "s3" }}{{ end }}
  backend "{{ $backendType }}" {
    {{- if or (eq $bt "") (eq $bt "local") }}
    path = "{{ .OpenTofu.Backend.Local.Path }}"
    {{- else if or (eq $bt "s3") (eq $bt "aws") }}
    bucket = "{{ .OpenTofu.Backend.S3.Bucket }}"
    key    = "{{ .OpenTofu.Backend.S3.Key }}"
    region = "{{ .OpenTofu.Backend.S3.Region }}"
    {{- if .GetS3BackendAccessKey }}
    access_key = "{{ .GetS3BackendAccessKey }}"
    {{- end }}
    {{- if .GetS3BackendSecretKey }}
    secret_key = "{{ .GetS3BackendSecretKey }}"
    {{- end }}
    {{- if .OpenTofu.Backend.S3.Endpoint }}
    endpoint = "{{ .OpenTofu.Backend.S3.Endpoint }}"
    {{- end }}
    {{- if .OpenTofu.Backend.S3.Profile }}
    profile = "{{ .OpenTofu.Backend.S3.Profile }}"
    {{- end }}
    {{- if .OpenTofu.Backend.S3.Encrypt }}
    encrypt = true
    {{- end }}
    {{- end }}
  }
}
